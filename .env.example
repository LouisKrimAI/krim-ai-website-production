# Krim website — environment configuration. Copy to .env.local and fill what you use.
# Everything is OPTIONAL: unset values disable the feature (no fake IDs, no dead tags).

# --- Analytics (pick ONE; both are public, inlined into the client bundle at build) ---
# Privacy-friendly, cookieless (recommended). Set to your domain, e.g. krim.ai
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# --- Search-engine verification (server-side; paste the token from each console) ---
# Google Search Console → Settings → Ownership → HTML tag → the content="..." value
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → verification meta → the content="..." value
BING_SITE_VERIFICATION=

# --- Demo booking: Calendly (public scheduling URL, inlined into the client) ---
# The full event URL, e.g. https://calendly.com/krim/30min
NEXT_PUBLIC_CALENDLY_URL=

# --- Demo booking: Supabase (server-only; lead capture lives here) ---
# Project URL, e.g. https://abcdefgh.supabase.co  (Project Settings → API)
SUPABASE_URL=
# Service-role key — SECRET, server-only, never NEXT_PUBLIC. (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# --- Demo booking: Resend (server-only; sends confirmation + drip + sales notice) ---
# API key from resend.com (Settings → API Keys). SECRET.
RESEND_API_KEY=
# Verified sender, e.g. "Krim <hello@krim.ai>". Domain must be verified in Resend.
EMAIL_FROM=
# Internal recipient that gets the new-lead notification.
EMAIL_SALES=sales@krim.ai

# --- Demo booking: drip cron + Calendly webhook (server-only) ---
# Shared secret protecting /api/cron/drip. Generate any long random string.
CRON_SECRET=
# Calendly webhook signing key (Calendly → Integrations → Webhooks). Verifies inbound bookings.
CALENDLY_WEBHOOK_SIGNING_KEY=
# Canonical site origin for building links in emails (no trailing slash), e.g. https://krim.ai
SITE_URL=https://krim.ai
